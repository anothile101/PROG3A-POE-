@model Practice_assignment.ViewModels.ServiceRequestCreateViewModel
@using Practice_assignment.Models
@{
    var contract = ViewBag.Contract as Contract;
    ViewData["Title"] = "New Service Request";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-clipboard-plus me-2"></i>New Service Request</h2>
    <a asp-controller="Contracts" asp-action="Details" asp-route-id="@contract?.Id"
       class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to Contract
    </a>
</div>

<!-- Contract Info Banner -->
<div class="alert alert-info d-flex align-items-center gap-3 mb-4">
    <i class="bi bi-file-earmark-text fs-4"></i>
    <div>
        <strong>Contract #@contract?.Id</strong> —
        @contract?.Client?.Name |
        <span class="badge bg-@(contract?.ServiceLevel == "Gold" ? "warning text-dark" : contract?.ServiceLevel == "Silver" ? "secondary" : "dark")">
            @contract?.ServiceLevel
        </span>
        <span class="ms-2 badge bg-@(contract?.Status == ContractStatus.Active ? "success" : "danger")">
            @contract?.Status
        </span>
    </div>
</div>

@if (contract?.Status == ContractStatus.Expired || contract?.Status == ContractStatus.OnHold)
{
    <div class="alert alert-danger">
        <i class="bi bi-lock-fill me-2"></i>
        <strong>Blocked:</strong> Service requests cannot be created for contracts with status
        <strong>@contract.Status</strong>. Please activate the contract first.
    </div>
}
else
{
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <i class="bi bi-clipboard-plus me-2"></i>Request Details
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <input type="hidden" asp-for="ContractId" />

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold"></label>
                            <textarea asp-for="Description" class="form-control" rows="4"
                                      placeholder="Describe the logistics service required..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <!-- Currency conversion section -->
                        <div class="mb-3">
                            <label asp-for="CostUsd" class="form-label fw-bold">Cost (USD)</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="CostUsd" class="form-control" type="number"
                                       step="0.01" min="0.01" id="costUsd"
                                       placeholder="0.00" />
                            </div>
                            <span asp-validation-for="CostUsd" class="text-danger small"></span>
                        </div>

                        <!-- Live ZAR conversion -->
                        <div class="mb-4">
                            <label class="form-label fw-bold text-success">
                                <i class="bi bi-currency-exchange me-1"></i>
                                Converted Cost (ZAR) — Live Rate
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-success text-white">R</span>
                                <input id="costZar" class="form-control bg-light fw-bold"
                                       readonly placeholder="Enter USD amount above..." />
                            </div>
                            <div class="form-text">
                                <i class="bi bi-info-circle me-1"></i>
                                Live exchange rate: <strong>1 USD = R @ViewBag.CurrentRate ZAR</strong>
                                <span class="text-muted">(auto-calculated on save)</span>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-send me-1"></i>Submit Request
                            </button>
                            <a asp-controller="Contracts" asp-action="Details"
                               asp-route-id="@contract?.Id"
                               class="btn btn-outline-secondary px-4">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        const rate = @ViewBag.CurrentRate;
        const usdInput = document.getElementById('costUsd');
        const zarDisplay = document.getElementById('costZar');

        if (usdInput) {
            usdInput.addEventListener('input', function () {
                const usd = parseFloat(this.value) || 0;
                zarDisplay.value = usd > 0 ? 'R ' + (usd * rate).toFixed(2) : '';
            });
        }
    </script>
}
