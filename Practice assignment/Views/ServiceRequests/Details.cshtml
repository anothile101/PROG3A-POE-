@model Practice_assignment.Models.ServiceRequest
@using Practice_assignment.Models
@{
    ViewData["Title"] = $"Service Request #{Model.Id}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-clipboard-check me-2"></i>Service Request #@Model.Id</h2>
    <a asp-controller="Contracts" asp-action="Details" asp-route-id="@Model.ContractId"
       class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to Contract
    </a>
</div>

<div class="row g-4 justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-info-circle me-2"></i>Request Details
            </div>
            <div class="card-body">
                <table class="table table-borderless">
                    <tr>
                        <th width="35%">Contract</th>
                        <td>
                            <a asp-controller="Contracts" asp-action="Details"
                               asp-route-id="@Model.ContractId">
                                #@Model.ContractId — @Model.Contract?.Client?.Name
                            </a>
                        </td>
                    </tr>
                    <tr>
                        <th>Description</th>
                        <td>@Model.Description</td>
                    </tr>
                    <tr>
                        <th>Cost (USD)</th>
                        <td class="fw-bold">$@Model.CostUsd.ToString("N2")</td>
                    </tr>
                    <tr>
                        <th>Cost (ZAR)</th>
                        <td class="fw-bold text-success">R @Model.CostZar.ToString("N2")</td>
                    </tr>
                    <tr>
                        <th>Exchange Rate Used</th>
                        <td class="text-muted">1 USD = @Model.ExchangeRateUsed.ToString("F4") ZAR</td>
                    </tr>
                    <tr>
                        <th>Status</th>
                        <td>
                            <span class="badge bg-@(Model.Status == ServiceRequestStatus.Completed ? "success" : Model.Status == ServiceRequestStatus.Cancelled ? "danger" : Model.Status == ServiceRequestStatus.InProgress ? "primary" : "secondary") fs-6">
                                @Model.Status
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <th>Created</th>
                        <td>@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>
