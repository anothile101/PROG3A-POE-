@model IEnumerable<Practice_assignment.Models.ServiceRequest>
@using Practice_assignment.Models
@{
    ViewData["Title"] = "Service Requests";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-clipboard-check me-2"></i>All Service Requests</h2>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-clipboard fs-1 d-block mb-3"></i>
                <p>No service requests found.</p>
                <a asp-controller="Contracts" asp-action="Index" class="btn btn-primary">
                    Go to Contracts to create one
                </a>
            </div>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Contract</th>
                        <th>Client</th>
                        <th>Description</th>
                        <th>Cost (USD)</th>
                        <th>Cost (ZAR)</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sr in Model)
                    {
                        <tr>
                            <td>#@sr.Id</td>
                            <td>
                                <a asp-controller="Contracts" asp-action="Details"
                                   asp-route-id="@sr.ContractId">
                                    #@sr.ContractId
                                </a>
                            </td>
                            <td>@sr.Contract?.Client?.Name</td>
                            <td class="text-truncate" style="max-width:200px;">@sr.Description</td>
                            <td>$@sr.CostUsd.ToString("N2")</td>
                            <td class="text-success fw-bold">R @sr.CostZar.ToString("N2")</td>
                            <td>
                                <span class="badge bg-@(sr.Status == ServiceRequestStatus.Completed ? "success" : sr.Status == ServiceRequestStatus.Cancelled ? "danger" : sr.Status == ServiceRequestStatus.InProgress ? "primary" : "secondary")">
                                    @sr.Status
                                </span>
                            </td>
                            <td class="small text-muted">@sr.CreatedAt.ToShortDateString()</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@sr.Id"
                                   class="btn btn-sm btn-outline-primary">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
