@model Practice_assignment.Models.Client
@{
    ViewData["Title"] = "New Client";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-plus me-2"></i>New Client</h2>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <i class="bi bi-person-plus me-2"></i>Client Details
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold"></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Global Freight Ltd" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ContactDetails" class="form-label fw-bold"></label>
                        <textarea asp-for="ContactDetails" class="form-control" rows="3"
                                  placeholder="e.g. info@company.com | +27 11 000 0000"></textarea>
                        <span asp-validation-for="ContactDetails" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Region" class="form-label fw-bold"></label>
                        <select asp-for="Region" class="form-select">
                            <option value="">-- Select Region --</option>
                            <option>Africa</option>
                            <option>Europe</option>
                            <option>Americas</option>
                            <option>Asia Pacific</option>
                            <option>Middle East</option>
                        </select>
                        <span asp-validation-for="Region" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success px-4">
                            <i class="bi bi-check-circle me-1"></i>Save Client
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
