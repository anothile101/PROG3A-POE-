@model Practice_assignment.Models.Client
@{
    ViewData["Title"] = Model.Name;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-circle me-2"></i>@Model.Name</h2>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to Clients
    </a>
</div>

<div class="row g-4">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-info-circle me-2"></i>Client Information
            </div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr>
                        <th width="40%">Name</th>
                        <td>@Model.Name</td>
                    </tr>
                    <tr>
                        <th>Contact</th>
                        <td>@Model.ContactDetails</td>
                    </tr>
                    <tr>
                        <th>Region</th>
                        <td><span class="badge bg-info text-dark">@Model.Region</span></td>
                    </tr>
                    <tr>
                        <th>Total Contracts</th>
                        <td>@Model.Contracts.Count</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">
                <i class="bi bi-file-earmark-text me-2"></i>Contracts
            </div>
            <div class="card-body p-0">
                @if (!Model.Contracts.Any())
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-inbox d-block fs-2 mb-2"></i>
                        No contracts for this client yet.
                    </div>
                }
                else
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Service Level</th>
                                <th>Status</th>
                                <th>Expires</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model.Contracts)
                            {
                                <tr>
                                    <td>#@c.Id</td>
                                    <td>@c.ServiceLevel</td>
                                    <td>
                                        <span class="badge bg-@(c.Status == ContractStatus.Active ? "success" : c.Status == ContractStatus.Expired ? "danger" : "secondary")">
                                            @c.Status
                                        </span>
                                    </td>
                                    <td>@c.EndDate.ToShortDateString()</td>
                                    <td>
                                        <a asp-controller="Contracts" asp-action="Details"
                                           asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">
                                            View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

@using Practice_assignment.Models
