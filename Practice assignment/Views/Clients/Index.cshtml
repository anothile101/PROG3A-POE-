@model IEnumerable<Practice_assignment.Models.Client>
@{
    ViewData["Title"] = "Clients";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people me-2"></i>Clients</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle me-1"></i> New Client
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-people fs-1 d-block mb-3"></i>
                <p>No clients found. Add your first client to get started.</p>
                <a asp-action="Create" class="btn btn-primary">Add Client</a>
            </div>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Contact Details</th>
                        <th>Region</th>
                        <th>Contracts</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td>@c.Id</td>
                            <td class="fw-bold">@c.Name</td>
                            <td class="text-muted small">@c.ContactDetails</td>
                            <td><span class="badge bg-info text-dark">@c.Region</span></td>
                            <td>
                                <span class="badge bg-secondary">
                                    @c.Contracts.Count contract(s)
                                </span>
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@c.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye me-1"></i>Details
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
