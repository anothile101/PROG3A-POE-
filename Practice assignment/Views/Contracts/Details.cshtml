@model Practice_assignment.Models.Contract
@{
    ViewData["Title"] = $"Contract #{Model.Id}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-file-earmark-text me-2"></i>Contract #@Model.Id</h2>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to Contracts
    </a>
</div>

<div class="row g-4">

    <!-- Contract Info Card -->
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-info-circle me-2"></i>Contract Details
            </div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr>
                        <th width="40%">Client</th>
                        <td>@Model.Client?.Name</td>
                    </tr>
                    <tr>
                        <th>Region</th>
                        <td>@Model.Client?.Region</td>
                    </tr>
                    <tr>
                        <th>Service Level</th>
                        <td>
                            <span class="badge bg-@(Model.ServiceLevel == "Gold" ? "warning text-dark" : Model.ServiceLevel == "Silver" ? "secondary" : "dark")">
                                @Model.ServiceLevel
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <th>Start Date</th>
                        <td>@Model.StartDate.ToShortDateString()</td>
                    </tr>
                    <tr>
                        <th>End Date</th>
                        <td>@Model.EndDate.ToShortDateString()</td>
                    </tr>
                    <tr>
                        <th>Status</th>
                        <td>
                            <span class="badge bg-@(Model.Status == ContractStatus.Active ? "success" : Model.Status == ContractStatus.Expired ? "danger" : Model.Status == ContractStatus.OnHold ? "warning text-dark" : "secondary")">
                                @Model.Status
                            </span>
                        </td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <!-- Actions Card -->
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-dark text-white">
                <i class="bi bi-gear me-2"></i>Actions
            </div>
            <div class="card-body d-flex flex-column gap-3">

                <!-- Change Status -->
                <div>
                    <h6 class="text-muted">Change Contract Status</h6>
                    <form asp-action="ChangeStatus" asp-route-id="@Model.Id" method="post" class="d-flex gap-2 flex-wrap">
                        @Html.AntiForgeryToken()
                        <select name="newStatus" class="form-select w-auto">
                            @foreach (var s in Enum.GetValues<ContractStatus>())
                            {
                                <option value="@s" selected="@(Model.Status == s)">@s</option>
                            }
                        </select>
                        <button type="submit" class="btn btn-outline-primary">
                            <i class="bi bi-arrow-repeat me-1"></i>Update Status
                        </button>
                    </form>
                </div>

                <hr />

                <!-- Signed Agreement -->
                <div>
                    <h6 class="text-muted">Signed Agreement</h6>
                    @if (Model.SignedAgreementPath != null)
                    {
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-file-earmark-pdf text-danger fs-4"></i>
                            <div>
                                <div class="small fw-bold">@Model.SignedAgreementFileName</div>
                                <a asp-action="Download" asp-route-id="@Model.Id"
                                   class="btn btn-sm btn-outline-danger mt-1">
                                    <i class="bi bi-download me-1"></i>Download PDF
                                </a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted small mb-0">
                            <i class="bi bi-exclamation-circle me-1"></i>No signed agreement uploaded yet.
                        </p>
                    }
                </div>

                <hr />

                <!-- New Service Request -->
                <div>
                    <h6 class="text-muted">Service Requests</h6>
                    @if (Model.Status == ContractStatus.Active || Model.Status == ContractStatus.Draft)
                    {
                        <a asp-controller="ServiceRequests" asp-action="Create"
                           asp-route-contractId="@Model.Id"
                           class="btn btn-success">
                            <i class="bi bi-plus-circle me-1"></i>New Service Request
                        </a>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0 py-2 small">
                            <i class="bi bi-lock me-1"></i>
                            Service requests cannot be created for <strong>@Model.Status</strong> contracts.
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>

    <!-- Service Requests Table -->
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <span><i class="bi bi-clipboard-check me-2"></i>Service Requests on this Contract</span>
                <span class="badge bg-secondary">@Model.ServiceRequests.Count total</span>
            </div>
            <div class="card-body p-0">
                @if (!Model.ServiceRequests.Any())
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                        No service requests yet.
                    </div>
                }
                else
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Description</th>
                                <th>Cost (USD)</th>
                                <th>Cost (ZAR)</th>
                                <th>Rate Used</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sr in Model.ServiceRequests.OrderByDescending(s => s.CreatedAt))
                            {
                                <tr>
                                    <td>@sr.Id</td>
                                    <td>@sr.Description</td>
                                    <td>$@sr.CostUsd.ToString("N2")</td>
                                    <td>R @sr.CostZar.ToString("N2")</td>
                                    <td class="text-muted small">@sr.ExchangeRateUsed.ToString("F4")</td>
                                    <td>
                                        <span class="badge bg-@(sr.Status == ServiceRequestStatus.Completed ? "success" : sr.Status == ServiceRequestStatus.Cancelled ? "danger" : sr.Status == ServiceRequestStatus.InProgress ? "primary" : "secondary")">
                                            @sr.Status
                                        </span>
                                    </td>
                                    <td class="small text-muted">@sr.CreatedAt.ToShortDateString()</td>
                                    <td>
                                        <a asp-controller="ServiceRequests" asp-action="Details"
                                           asp-route-id="@sr.Id" class="btn btn-sm btn-outline-info">
                                            View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

</div>

@using Practice_assignment.Models
